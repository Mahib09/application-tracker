// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(uuid()) @db.Uuid
  email      String   @unique
  name       String?
  image      String?
  createdAt  DateTime @default(now())
  upadatedAt DateTime @updatedAt

  applications Application[]
  sync_state   SyncState?
  oauth_token  OauthToken?
}

model Application {
  id        String            @id @default(uuid()) @db.Uuid
  userId    String            @db.Uuid
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   String
  roleTitle String
  status    applicationStatus @default(APPLIED)
  source    applicationSource

  appliedAt DateTime?
  jobUrl    String?
  location  String?
  notes     String?

  confidence            Float?
  manuallyEdited        Boolean   @default(false)
  sourceEmailId         String?
  sourceEmailSubject    String?
  sourceEmailSnippet    String?
  sourceEmailReceivedAt DateTime?

  interviewDate     DateTime?
  interviewUrl      String?
  interviewer       String?
  interviewProvider String?

  recruiterName           String?
  recruiterEmail          String?
  lastFollowUpAt          DateTime?
  jobDescriptionSnapshot  String?
  jobDescriptionFetchedAt DateTime?

  tags String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  statusChanges StatusChange[]

  @@index([userId, status])
  @@index([userId, appliedAt])
  @@index([userId, confidence])
}

model StatusChange {
  id            String            @id @default(uuid()) @db.Uuid
  applicationId String            @db.Uuid
  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  fromStatus    applicationStatus
  toStatus      applicationStatus
  trigger       changeTrigger     @default(MANUAL)
  eventDate     DateTime?
  createdAt     DateTime          @default(now())

  @@index([applicationId, createdAt])
}

model SyncState {
  userId         String          @id @db.Uuid
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastSyncedAt   DateTime?
  lastSyncStatus lastSyncStatus?
  lastSyncError  String?

  emailsFetched        Int?
  emailsClassified     Int?
  aiCallCount          Int?
  sonnetCallCount      Int?
  filteredCount        Int?
  haikuCallCount       Int?
  triageYesCount       Int?
  triageNoCount        Int?
  triageUncertainCount Int?
  autoCommitCount      Int?
  reviewFlagCount      Int?
  manualQueueCount     Int?

  updatedAt DateTime @updatedAt
}

model OauthToken {
  userId       String    @id @db.Uuid
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String
  refreshToken String
  expiresAt    DateTime?
  scope        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum applicationStatus {
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
  GHOSTED
  NEEDS_REVIEW
}

enum applicationSource {
  MANUAL
  GMAIL
}

enum lastSyncStatus {
  SUCCESS
  FAIL
  IN_PROGRESS
}

enum changeTrigger {
  MANUAL
  SYNC
  AUTO_GHOST
  DRAG_DROP
  COMMAND_PALETTE
}
